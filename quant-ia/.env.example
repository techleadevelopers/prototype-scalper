DRIFT_VOLUME_RATIO_CRITICAL=0.25
DRIFT_UNIVERSE_CHANGE_WARN=0.15
DRIFT_UNIVERSE_CHANGE_CRITICAL=0.30
DRIFT_PREDICTION_AGE_WARN_SECONDS=120
DRIFT_PREDICTION_AGE_CRITICAL_SECONDS=300
DRIFT_BRIER_WARN=0.22
DRIFT_BRIER_CRITICAL=0.28
