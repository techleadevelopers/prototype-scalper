# 0 preserves realized demo/live trades indefinitely.
RETENTION_TRADE_OUTCOMES_DAYS=0

# Drift monitoring: reference/current windows and deterministic thresholds.
DRIFT_REFERENCE_SAMPLES=500
DRIFT_CURRENT_SAMPLES=100
DRIFT_MIN_SAMPLES=50
DRIFT_BINS=10
DRIFT_PSI_WARN=0.10
DRIFT_PSI_CRITICAL=0.25
