modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Quant Brain"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Quant Brain"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/quant-brain && PORT=9000 python main.py"
waitForPort = 9000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm run build && PORT=8080 pnpm run start"
waitForPort = 8080

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/bingx-dashboard && PORT=5000 BASE_PATH=/ VITE_API_URL=http://localhost:8080 pnpm run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 9000
externalPort = 9000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "postgresql"]

[userenv]

[userenv.shared]
QUANT_BRAIN_URL = "http://localhost:9000"
QUANT_BRAIN_ENABLED = "true"
QUANT_BRAIN_GATE_MODE = "shadow"
QUANT_BRAIN_TIMEOUT_MS = "8000"
QUANT_BRAIN_SHADOW_EDGE_TIMEOUT_MS = "2500"
QUANT_BRAIN_ENFORCE_EDGE_TIMEOUT_MS = "8000"
QUANT_BRAIN_INTELLIGENCE_TIMEOUT_MS = "4000"
QUANT_BRAIN_SUMMARY_TIMEOUT_MS = "1500"
QUANT_BRAIN_SUMMARY_CACHE_TTL_MS = "15000"
SCALP_SIGNAL_SOURCE_TYPE = "live"
SCALP_LEVERAGE = "14"
SCALP_MARGIN_PER_TRADE = "5"
SCALP_MAX_CONCURRENT_POSITIONS = "20"
SCALP_MAX_MARGIN_UTILIZATION = "0.5"
SCALP_TAKE_PROFIT_PCT = "0.50"
SCALP_STOP_LOSS_PCT = "0.35"
SCALP_EV_MIN_THRESHOLD = "0.0003"
SCALP_WIN_RATE_MIN = "0.52"
SCALP_PROFIT_FACTOR_MIN = "1.1"
SCALP_BTC_REGIME_REQUIRED = "true"
SCALP_BTC_REGIME_THRESHOLD_PCT = "0.5"
SCALP_SYMBOLS = "BTC-USDT,VVV-USDT,ETH-USDT,SOL-USDT,TRUMP-USDT,MELANIA-USDT,BEAT-USDT,NEAR-USDT,HYPE-USDT,POL-USDT"
SCALP_HOUR_BLACKLIST = ""
SCALP_ORDER_TYPE = "MARKET"
SCALP_MARGIN_TYPE = "ISOLATED"
SCALP_ALLOW_EXECUTION = "true"
SCALP_MAX_SESSION_LOSS = "20"
QUANT_BRAIN_DB_SCHEMA = "quant_brain"
QUANT_BRAIN_DB_POOL_SIZE = "5"
QUANT_BRAIN_DB_COMMAND_TIMEOUT = "30"
DB_INIT_TIMEOUT_SECONDS = "20"
DB_INIT_RETRY_SECONDS = "10"
MODEL_MAINTENANCE_SECONDS = "120"
TACTICAL_LOOP_SECONDS = "15"
JOB_MAX_CONCURRENCY = "3"
JOB_STALE_AFTER_SECONDS = "120"
TACTICAL_JOB_TIMEOUT_SECONDS = "20"
SHADOW_SAMPLER_JOB_TIMEOUT_SECONDS = "25"
MODEL_JOB_TIMEOUT_SECONDS = "45"
MACRO_CANDLE_ANALYSIS_SECONDS = "900"
MACRO_CANDLE_JOB_TIMEOUT_SECONDS = "30"
FEATURE_HTTP_CONCURRENCY = "8"
FEATURE_SNAPSHOT_CONCURRENCY = "3"
FEATURE_HTTP_TIMEOUT_SECONDS = "4"
SHADOW_SAMPLER_ENABLED = "true"
SHADOW_SAMPLER_INTERVAL_SECONDS = "60"
SHADOW_SAMPLER_WINDOW_SECONDS = "300"
SHADOW_SAMPLER_DEDUPE_SECONDS = "300"
SHADOW_SAMPLER_BOOTSTRAP_SAMPLES = "3"
SIGNAL_OUTCOME_WINDOW_SECONDS = "300"
SIGNAL_OUTCOME_MIN_AGE_SECONDS = "300"
SHADOW_SAMPLER_LEVERAGE = "14"
SHADOW_SAMPLER_MARGIN_PER_TRADE = "5"
SHADOW_SAMPLER_TAKE_PROFIT_PCT = "0.50"
SHADOW_SAMPLER_STOP_LOSS_PCT = "0.35"
SHADOW_SAMPLER_TAKER_FEE_BPS = "5"
SHADOW_SAMPLER_SLIPPAGE_BPS_PER_SIDE = "2"
SHADOW_SAMPLER_ESTIMATED_FUNDING_COST_PCT = "0"
SHADOW_MODEL_SIGNAL_SOURCE_TYPE = ""
RETENTION_MAINTENANCE_SECONDS = "3600"
RETENTION_FEATURE_SNAPSHOTS_HOURS = "24"
RETENTION_SIGNAL_OUTCOMES_DAYS = "60"
RETENTION_NEWS_EVENTS_DAYS = "3"
RETENTION_OBSERVATIONS_DAYS = "14"
RETENTION_EXECUTION_QUALITY_DAYS = "14"
RETENTION_TRADE_OUTCOMES_DAYS = "0"
SCALP_POSITION_STACKING_ENABLED = "true"
SCALP_MAX_POSITIONS_PER_SYMBOL = "3"
SCALP_SNIPER_MIN_COMBINED_SCORE = "0.55"
SCALP_AUTOPILOT_MAX_CANDIDATES = "15"
